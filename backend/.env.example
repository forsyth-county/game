# Server Configuration
PORT=3001

# CORS Configuration (your frontend domain)
FRONTEND_URL=https://forsyth-county.github.io

# Admin API Key for security (generate a strong random string)
ADMIN_API_KEY=your-secret-api-key-here

# 2FA Display Page Passcode (4-digit code required to view 2FA codes)
PASSCODE=1100

# Generate a secure API key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Note: CORS is configured to allow multiple origins including GitHub Pages and localhost
